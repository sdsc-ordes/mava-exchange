@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix ex: <http://example.org/data/> .
@prefix mava: <http://example.org/mava/ontology#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:package a mava:MediaPackage ;
    mava:hasVideo ex:video_video_001,
        ex:video_video_002 ;
    dcterms:created "2026-02-23T08:22:21.506352+00:00"^^xsd:dateTime ;
    dcterms:description "Example corpus: two videos with different annotation tracks" .

ex:dim_dominant_color_b a mava:Dimension ;
    mava:dimensionDescription "Blue channel of dominant color" ;
    mava:dimensionName "b" ;
    mava:valueRange "[0,1]" .

ex:dim_dominant_color_g a mava:Dimension ;
    mava:dimensionDescription "Green channel of dominant color" ;
    mava:dimensionName "g" ;
    mava:valueRange "[0,1]" .

ex:dim_dominant_color_r a mava:Dimension ;
    mava:dimensionDescription "Red channel of dominant color" ;
    mava:dimensionName "r" ;
    mava:valueRange "[0,1]" .

ex:dim_emotions_angry a mava:Dimension ;
    mava:dimensionDescription "Anger probability" ;
    mava:dimensionName "angry" ;
    mava:valueRange "[0,1]" .

ex:dim_emotions_disgust a mava:Dimension ;
    mava:dimensionDescription "Disgust probability" ;
    mava:dimensionName "disgust" ;
    mava:valueRange "[0,1]" .

ex:dim_emotions_fear a mava:Dimension ;
    mava:dimensionDescription "Fear probability" ;
    mava:dimensionName "fear" ;
    mava:valueRange "[0,1]" .

ex:dim_emotions_happy a mava:Dimension ;
    mava:dimensionDescription "Happiness probability" ;
    mava:dimensionName "happy" ;
    mava:valueRange "[0,1]" .

ex:dim_emotions_neutral a mava:Dimension ;
    mava:dimensionDescription "Neutral expression" ;
    mava:dimensionName "neutral" ;
    mava:valueRange "[0,1]" .

ex:dim_emotions_sad a mava:Dimension ;
    mava:dimensionDescription "Sadness probability" ;
    mava:dimensionName "sad" ;
    mava:valueRange "[0,1]" .

ex:dim_emotions_surprise a mava:Dimension ;
    mava:dimensionDescription "Surprise probability" ;
    mava:dimensionName "surprise" ;
    mava:valueRange "[0,1]" .

ex:dim_rms_volume_rms a mava:Dimension ;
    mava:dimensionDescription "Root mean square audio volume" ;
    mava:dimensionName "rms" ;
    mava:valueRange ">=0" .

ex:series_dominant_color a mava:ObservationSeries ;
    mava:hasDimension ex:dim_dominant_color_b,
        ex:dim_dominant_color_g,
        ex:dim_dominant_color_r ;
    mava:samplingInterval 0.5 ;
    mava:seriesDescription "Dominant RGB color sampled every 0.5s. Each channel is a float in [0,1]." .

ex:series_emotions a mava:ObservationSeries ;
    mava:hasDimension ex:dim_emotions_angry,
        ex:dim_emotions_disgust,
        ex:dim_emotions_fear,
        ex:dim_emotions_happy,
        ex:dim_emotions_neutral,
        ex:dim_emotions_sad,
        ex:dim_emotions_surprise ;
    mava:samplingInterval 0.5 ;
    mava:seriesDescription "Per-frame probability scores from face analysis model, sampled every 0.5s." .

ex:series_face_emotions a mava:AnnotationSeries ;
    mava:seriesDescription "Dominant face emotion label per detected interval." .

ex:series_rms_volume a mava:ObservationSeries ;
    mava:hasDimension ex:dim_rms_volume_rms ;
    mava:samplingInterval 0.064 ;
    mava:seriesDescription "RMS audio volume sampled at ~0.064s intervals." .

ex:series_transcript a mava:AnnotationSeries ;
    mava:seriesDescription "Speech-to-text segments from Whisper transcription model." .

ex:video_video_001 a mava:Video ;
    mava:hasAnalysis ex:series_emotions,
        ex:series_face_emotions,
        ex:series_shots,
        ex:series_transcript ;
    dcterms:source <https://example.org/videos/talk_001.mp4> .

ex:video_video_002 a mava:Video ;
    mava:hasAnalysis ex:series_dominant_color,
        ex:series_rms_volume,
        ex:series_shots ;
    dcterms:source <https://example.org/videos/talk_002.mp4> .

ex:series_shots a mava:AnnotationSeries ;
    mava:seriesDescription "Shot boundary intervals detected by scene detection model." .
