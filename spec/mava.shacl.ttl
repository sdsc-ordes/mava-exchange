@prefix mava:    <http://example.org/mava/ontology#> .
@prefix sh:      <http://www.w3.org/ns/shacl#> .
@prefix xsd:     <http://www.w3.org/2001/XMLSchema#> .

# ═══════════════════════════════════════════════════════════════════════
# MAVA SHACL Shapes
#
# Validation rules for RDF data exported from a .mediapkg file.
#
# These shapes are organized into two categories:
#
# 1. MANIFEST SHAPES — validate the package structure (videos, tracks)
#    - MediaPackageShape
#    - VideoShape
#    - ObservationSeriesShape
#    - AnnotationSeriesShape
#    - AnnotationListSeriesShape
#    - DimensionShape
#
# 2. DATA SHAPES — validate individual Parquet rows exported as RDF
#    - ObservationPointShape
#    - AnnotationShape (parent for both single and list segments)
#    - AnnotationSegmentShape
#    - AnnotationListSegmentShape
#
# The manifest shapes correspond to the manifest.json structure.
# The data shapes correspond to rows in the Parquet files.
#
# In a typical RDF export:
# - The manifest becomes ~10-100 triples (package + videos + track defs)
# - The data becomes 1,000-1,000,000 triples (one triple set per row)
#
# For validating .mediapkg files, use src/mava_exchange/validate.py instead.
# These SHACL shapes are for validating RDF exports only.
# ═══════════════════════════════════════════════════════════════════════


# ═════════════════════════════════════════════════════════════════════
# PART 1: MANIFEST SHAPES
# These validate the package structure from manifest.json
# ═════════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────────
# MediaPackage
# A MediaPackage in a .mediapkg context must have at least one video.
# ───────────────────────────────────────────────────────────────────────

mava:MediaPackageShape a sh:NodeShape ;
    sh:targetClass mava:MediaPackage ;
    sh:description   "Every MediaPackage must have at least one video." ;

    sh:property [
        sh:path      mava:hasVideo ;
        sh:minCount  1 ;
        sh:class     mava:Video ;
        sh:message "A MediaPackage with no videos is not useful in this context." ;
    ] .

# ───────────────────────────────────────────────────────────────────────
# Video
# A Video in a .mediapkg context must have at least one analysis series.
# ───────────────────────────────────────────────────────────────────────

mava:VideoShape a sh:NodeShape ;
    sh:targetClass mava:Video ;
    sh:description   "Every Video must have at least one analysis series." ;

    sh:property [
        sh:path      mava:hasAnalysis ;
        sh:minCount  1 ;
        sh:or (
            [ sh:class mava:ObservationSeries ]
            [ sh:class mava:AnnotationSeries ]
            [ sh:class mava:AnnotationListSeries ]
            [ sh:class mava:RegionSeries ]
        ) ;
        sh:message "A Video with no analysis series is not useful in this context." ;
    ] .

# ───────────────────────────────────────────────────────────────────────
# AnnotationSeries
# Every AnnotationSeries must have a description.
# ───────────────────────────────────────────────────────────────────────

mava:AnnotationSeriesShape a sh:NodeShape ;
    sh:targetClass mava:AnnotationSeries ;
    sh:description   "Every AnnotationSeries must have a description." ;

    sh:property [
        sh:path mava:seriesDescription ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
    ] .

# ───────────────────────────────────────────────────────────────────────
# AnnotationListSeries
# Every AnnotationListSeries must have a description.
# ───────────────────────────────────────────────────────────────────────

mava:AnnotationListSeriesShape a sh:NodeShape ;
    sh:targetClass mava:AnnotationListSeries ;
    sh:description   "Every AnnotationListSeries must have a description." ;

    sh:property [
        sh:path mava:seriesDescription ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
    ] .

# ───────────────────────────────────────────────────────────────────────
# ObservationSeries
# Every ObservationSeries must have a description and a dimension.
# It may also have a sampling interval in case the sampling is regular.
# ───────────────────────────────────────────────────────────────────────

mava:ObservationSeriesShape a sh:NodeShape ;
    sh:targetClass mava:ObservationSeries ;
    sh:description   "Every ObservationSeries must have a description." ;

    sh:property [
        sh:path     mava:seriesDescription ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
    ] ;

    sh:property [
        sh:path      mava:hasDimension ;
        sh:class     mava:Dimension ;
        sh:minCount  1 ;
        sh:message "Must declare at least one dimension (column)." ;
    ] ;

    sh:property [
        sh:path        mava:samplingInterval ;
        sh:maxCount    1 ;
        sh:datatype    xsd:decimal ;
        sh:minExclusive 0 ;
        sh:message   "Optional. If present, must be a positive number." ;
    ] .

# ───────────────────────────────────────────────────────────────────────
# RegionSeries
# Every RegionSeries must have a description and at least one dimension
# (the geometry/score columns). It may declare a coordinate space and a
# sampling interval.
# ───────────────────────────────────────────────────────────────────────

mava:RegionSeriesShape a sh:NodeShape ;
    sh:targetClass mava:RegionSeries ;
    sh:description   "Every RegionSeries must have a description and a dimension." ;

    sh:property [
        sh:path     mava:seriesDescription ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
    ] ;

    sh:property [
        sh:path      mava:hasDimension ;
        sh:class     mava:Dimension ;
        sh:minCount  1 ;
        sh:message "Must declare at least one dimension (geometry/score column)." ;
    ] ;

    sh:property [
        sh:path        mava:coordinateSpace ;
        sh:maxCount    1 ;
        sh:datatype    xsd:string ;
        sh:in          ( "normalized" "pixel" ) ;
        sh:message   "Optional. If present, must be 'normalized' or 'pixel'." ;
    ] ;

    sh:property [
        sh:path        mava:samplingInterval ;
        sh:maxCount    1 ;
        sh:datatype    xsd:decimal ;
        sh:minExclusive 0 ;
        sh:message   "Optional. If present, must be a positive number." ;
    ] .

# ───────────────────────────────────────────────────────────────────────
# Dimension
# Every dimension must have exactly one name matching its Parquet column.
# ───────────────────────────────────────────────────────────────────────

mava:DimensionShape a sh:NodeShape ;
    sh:targetClass mava:Dimension ;
    sh:description   "Every Dimension must have a name matching its Parquet column." ;

    sh:property [
        sh:path      mava:dimensionName ;
        sh:minCount  1 ;
        sh:maxCount  1 ;
        sh:datatype  xsd:string ;
        sh:message "Exactly one name, matching the Parquet column name." ;
    ] ;

    sh:property [
        sh:path      mava:dimensionDescription ;
        sh:minCount  1 ;
        sh:maxCount  1 ;
        sh:datatype  xsd:string ;
        sh:message "Exactly one description." ;
    ] ;

    sh:property [
        sh:path      mava:valueRange ;
        sh:maxCount  1 ;
        sh:datatype  xsd:string ;
        sh:message "Optional. If present, must be a string describing the value range." ;
    ] .

# ═════════════════════════════════════════════════════════════════════
# PART 2: DATA SHAPES
# These validate individual Parquet rows in case they were
# exported as RDF (not implemented in this package yet).
# ═════════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────────
# ObservationPoint
# Validates one row from an ObservationSeries Parquet file
# ───────────────────────────────────────────────────────────────────────

mava:ObservationPointShape a sh:NodeShape ;
    sh:targetClass mava:ObservationPoint ;
    sh:description   "Every ObservationPoint must have a time and belong to a series." ;

    sh:property [
        sh:path         mava:atTime ;
        sh:minCount     1 ;
        sh:maxCount     1 ;
        sh:datatype     xsd:decimal ;
        sh:minInclusive 0 ;
        sh:message "Exactly one time value, non-negative." ;
    ] ;

    sh:property [
        sh:path      mava:belongsToObservationSeries ;
        sh:minCount  1 ;
        sh:maxCount  1 ;
        sh:message "Must belong to exactly one ObservationSeries." ;
    ] ;

    sh:property [
        sh:path      mava:numericValue ;
        sh:minCount  1 ;
        sh:datatype  xsd:decimal ;
        sh:message "Must have at least one numeric value." ;
    ] .

# ───────────────────────────────────────────────────────────────────────
# RegionDetection
# Validates one row from a RegionSeries Parquet file. Geometry datatypes are
# checked here; the [0,1] bound for normalized coordinates is enforced by
# src/mava_exchange/validate.py, which can read the series' coordinate_space.
# ───────────────────────────────────────────────────────────────────────

mava:RegionDetectionShape a sh:NodeShape ;
    sh:targetClass mava:RegionDetection ;
    sh:description   "Every RegionDetection must have a time, belong to a series, and carry box geometry, a score and a cluster id." ;

    sh:property [
        sh:path         mava:atTime ;
        sh:minCount     1 ;
        sh:maxCount     1 ;
        sh:datatype     xsd:decimal ;
        sh:minInclusive 0 ;
        sh:message "Exactly one time value, non-negative." ;
    ] ;

    sh:property [
        sh:path      mava:belongsToRegionSeries ;
        sh:minCount  1 ;
        sh:maxCount  1 ;
        sh:message "Must belong to exactly one RegionSeries." ;
    ] ;

    sh:property [
        sh:path      mava:x ;
        sh:minCount  1 ;
        sh:maxCount  1 ;
        sh:datatype  xsd:decimal ;
    ] ;

    sh:property [
        sh:path      mava:y ;
        sh:minCount  1 ;
        sh:maxCount  1 ;
        sh:datatype  xsd:decimal ;
    ] ;

    sh:property [
        sh:path      mava:width ;
        sh:minCount  1 ;
        sh:maxCount  1 ;
        sh:datatype  xsd:decimal ;
    ] ;

    sh:property [
        sh:path      mava:height ;
        sh:minCount  1 ;
        sh:maxCount  1 ;
        sh:datatype  xsd:decimal ;
    ] ;

    sh:property [
        sh:path         mava:detectionScore ;
        sh:maxCount     1 ;
        sh:datatype     xsd:decimal ;
        sh:minInclusive 0 ;
        sh:maxInclusive 1 ;
        sh:message "Detection confidence in [0,1]." ;
    ] ;

    sh:property [
        sh:path      mava:clusterId ;
        sh:minCount  1 ;
        sh:maxCount  1 ;
        sh:datatype  xsd:integer ;
        sh:message "Exactly one machine cluster id." ;
    ] ;

    sh:property [
        sh:path      mava:identityLabel ;
        sh:maxCount  1 ;
        sh:datatype  xsd:string ;
        sh:message "Optional, nullable human label." ;
    ] .

# ───────────────────────────────────────────────────────────────────────
# Annotation (parent shape)
# Common constraints for all annotation types.
# ───────────────────────────────────────────────────────────────────────

mava:AnnotationShape a sh:NodeShape ;
    sh:targetClass  mava:Annotation ;
    sh:description  "Every Annotation must have start time and end time." ;

    sh:property [
        sh:path         mava:startTime ;
        sh:minCount     1 ;
        sh:maxCount     1 ;
        sh:datatype     xsd:decimal ;
        sh:minInclusive 0 ;
        sh:message      "Exactly one start time, non-negative." ;
    ] ;

    sh:property [
        sh:path         mava:endTime ;
        sh:minCount     1 ;
        sh:maxCount     1 ;
        sh:datatype     xsd:decimal ;
        sh:minInclusive 0 ;
        sh:message      "Exactly one end time, non-negative. Must be greater than start time (constraint not enforced by SHACL)." ;
    ] .


# ───────────────────────────────────────────────────────────────────────
# AnnotationSegment
# Validates one row from an AnnotationSeries Parquet file.
# ───────────────────────────────────────────────────────────────────────

mava:AnnotationSegmentShape a sh:NodeShape ;
    sh:targetClass  mava:AnnotationSegment ;
    sh:description  "Every AnnotationSegment must belong to an AnnotationSeries and have a string value." ;

    sh:property [
        sh:path     mava:belongsToAnnotationSeries ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message  "Must belong to exactly one AnnotationSeries." ;
    ] ;

    sh:property [
        sh:path     mava:stringValue ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message  "Must have exactly one string value." ;
    ] .


# ───────────────────────────────────────────────────────────────────────
# AnnotationListSegment
# Validates one row from an AnnotationListSeries Parquet file.
# ───────────────────────────────────────────────────────────────────────

mava:AnnotationListSegmentShape a sh:NodeShape ;
    sh:targetClass  mava:AnnotationListSegment ;
    sh:description  "Every AnnotationListSegment must belong to an AnnotationListSeries and have list values." ;

    sh:property [
        sh:path     mava:belongsToAnnotationListSeries ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message  "Must belong to exactly one AnnotationListSeries." ;
    ] ;

    sh:property [
        sh:path     mava:listValue ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
        sh:message  "Must have at least one list value (multi-valued property in RDF)." ;
    ] .
